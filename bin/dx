#!/usr/bin/env bash
# =============================================================================
# dx — Developer Workflow CLI
# Unifies Jira, Confluence, GitLab, and GitHub into a single command
# =============================================================================
set -euo pipefail

# Resolve symlinks so LIB_DIR points to the real repo regardless of install location
_SELF="${BASH_SOURCE[0]}"
while [[ -L "$_SELF" ]]; do
  _SELF="$(readlink "$_SELF")"
  [[ "$_SELF" == /* ]] || _SELF="$(dirname "${BASH_SOURCE[0]}")/$_SELF"
done
SCRIPT_DIR="$(cd "$(dirname "$_SELF")" && pwd)"
unset _SELF
LIB_DIR="$SCRIPT_DIR/../lib"

source "$LIB_DIR/config.sh"
source "$LIB_DIR/atlassian.sh"
source "$LIB_DIR/gitlab.sh"
source "$LIB_DIR/github.sh"
source "$LIB_DIR/git.sh"
source "$LIB_DIR/template.sh"
source "$LIB_DIR/template_cmd.sh"
source "$LIB_DIR/ai_output.sh"
source "$LIB_DIR/excludes.sh"
source "$LIB_DIR/budget.sh"
source "$LIB_DIR/changed.sh"
source "$LIB_DIR/search.sh"
source "$LIB_DIR/diff.sh"
source "$LIB_DIR/analyze.sh"
source "$LIB_DIR/scan.sh"
source "$LIB_DIR/repox.sh"
source "$LIB_DIR/context.sh"
source "$LIB_DIR/ci.sh"
source "$LIB_DIR/guard.sh"
source "$LIB_DIR/diagnose.sh"
source "$LIB_DIR/body.sh"
source "$LIB_DIR/version.sh"

CMD="${1:-help}"
shift || true

if [[ "$CMD" == "auth" ]]; then
  case "${1:-}" in
    login|profile|default|switch)
      DX_ALLOW_MISSING_PROFILE=1
      ;;
  esac
elif [[ "$CMD" == "profile" ]]; then
  DX_ALLOW_MISSING_PROFILE=1
elif [[ "$CMD" == "env" || "$CMD" == "doctor" || "$CMD" == "update" || "$CMD" == "version" || "$CMD" == "--version" ]]; then
  DX_ALLOW_MISSING_PROFILE=1
fi

config_load
unset DX_ALLOW_MISSING_PROFILE

_dx_help() {
  cat <<'HELP'
dx — Developer Workflow CLI

USAGE
  dx auth login                Create/edit global config (~/.config/dx/default.env)
  dx auth profile <name>       Create or edit a named profile
  dx auth profile list         List all profiles
  dx auth profile delete <name> Delete a named profile
  dx auth default <name>       Save a default profile for future dx commands
  dx auth switch <name>        Print export command to activate a profile
  dx auth switch <name> --save Activate and save as default profile
  dx auth whoami               Show active config + test connections
  dx env check                 Check local tools and dx config presence
  dx doctor                    Diagnose dx setup and optional integrations
  dx version                   Print dx version and install details
  dx update --check            Check latest GitHub release tag

  dx profile delete <name>     Shortcut for dx auth profile delete <name>

  dx jira read <TICKET|URL>            Human-readable ticket
  dx jira read <TICKET|URL> --ai       Compact format for AI
  dx jira read <TICKET|URL> --raw      Raw JSON
  dx jira list <PROJECT-KEY>           List open tickets
  dx jira search "<query>"             Text search (default)
  dx jira search "<query>" --jql       Treat query as raw JQL
  dx jira open <TICKET|URL>            Open in browser

  dx confluence read <URL|PAGE-ID>         Human-readable page
  dx confluence read <URL|PAGE-ID> --ai    Compact for AI
  dx confluence search "<query>" --limit 5 --ai

  dx code search <query> --ai              Compact ripgrep search for AI
  dx code search <query> --path lib --ai   Search selected paths
  dx code search <query> --changed --ai    Search only changed files
  dx file find <query> --ai                Compact fd file finder for AI
  dx file find <query> --path test --ai    Find files under selected paths

  dx diff --ai                             Compact git diff summary
  dx diff --base origin/main --ai          Compare against a specific base
  dx diff --ai --b s                       Small token budget output
  dx diff --ai --budget full               Larger token budget output
  dx diff --files --ai                     Show changed files only

  dx analyze flutter --ai                  Compact flutter analyze summary
  dx scan security --ai                    Compact Trivy security scan
  dx scan security --changed --ai          Changed-file security scan workflow
  dx scan security --severity CRITICAL,HIGH --ai
  dx scan security --scanners vuln,secret,misconfig --ai
  dx repox summary --ai                    Summarize available repox outputs
  dx template list                         List available MR/PR templates
  dx template path <name>                  Print the resolved template file path
  dx context <TICKET|URL> --ai             Stateless Jira-centered work context
  dx context <TICKET|URL> --include-diff --ai --b f
  dx context <TICKET|URL> --with-repox --ai Optional Repox context

  dx guard pre-mr --ai                     Stateless pre-MR risk checks
  dx guard pre-mr --changed --ai           Scope guard checks to changed files
  dx guard pre-commit --ai                 Stateless pre-commit risk checks
  dx guard pre-mr --security --ai          Include Trivy security scan
  dx guard pre-commit --security --ai      Include Trivy security scan

  dx mr open <TICKET>                   Create GitLab MR from ticket
  dx mr open <TICKET> --draft           Create as Draft
  dx mr open <TICKET> --type <type>     Commit type: feat|fix|chore|... (default: feat)
  dx mr open <TICKET> --target <branch> Override target branch
  dx mr open <TICKET> --changelog "..."  Override changelog
  dx mr open <TICKET> --body-file <path> Use an AI-generated MR body markdown file
  dx mr open <TICKET> --template <name>  Use a named MR template (default: mr_description_mobile)
  dx mr open <TICKET> --yes             Skip repo/profile confirmation prompt
  dx mr body <TICKET> --include-diff     Generate MR body markdown without opening MR
  dx mr list                             List open MRs assigned to me
  dx mr view <MR-ID>                     Open MR in browser

  dx pr open <TICKET>                   Create GitHub PR from ticket
  dx pr open <TICKET> --draft           Create as Draft
  dx pr open <TICKET> --type <type>     Commit type: feat|fix|chore|... (default: feat)
  dx pr open <TICKET> --target <branch> Override target branch
  dx pr open <TICKET> --changelog "..."  Override changelog
  dx pr open <TICKET> --body-file <path> Use an AI-generated PR body markdown file
  dx pr open <TICKET> --template <name>  Use a named PR template (default: mr_description_mobile)
  dx pr open <TICKET> --yes             Skip repo/profile confirmation prompt
  dx pr body <TICKET> --include-diff     Generate PR body markdown without opening PR
  dx pr list                             List open PRs assigned to me
  dx pr view <PR-ID>                     Open PR in browser

EXAMPLES
  dx jira read DE-1234
  dx jira read DE-1234 --ai
  dx confluence read https://yourco.atlassian.net/wiki/spaces/.../pages/12345/...
  dx code search "Bloc" --ai
  dx diff --ai
  dx diff --ai --b s
  dx context DE-1234 --include-diff --with-repox --ai
  dx mr body DE-1234 --include-diff --output /tmp/mr.md
  dx mr open DE-1234 --draft
  dx pr open DE-1234 --target develop
HELP
}

case "$CMD" in
  jira)
    config_validate_atlassian
    _atlassian_init
    SUB="${1:-}"
    [[ $# -gt 0 ]] && shift || true
    case "$SUB" in
      read)   atlassian_read "$@" ;;
      list)   atlassian_list "$@" ;;
      search) atlassian_search "$@" ;;
      open)   atlassian_open "$@" ;;
      *)      echo "Usage: dx jira read|list|search|open" >&2; exit 1 ;;
    esac
    ;;

  confluence)
    config_validate_atlassian
    _atlassian_init
    SUB="${1:-}"
    [[ $# -gt 0 ]] && shift || true
    case "$SUB" in
      read)   atlassian_confluence "$@" ;;
      search) atlassian_confluence_search "$@" ;;
      *)      echo "Usage: dx confluence read|search" >&2; exit 1 ;;
    esac
    ;;

  code)
    dx_code_search "$@"
    ;;

  file)
    dx_file_find "$@"
    ;;

  diff)
    dx_diff "$@"
    ;;

  analyze)
    dx_analyze "$@"
    ;;

  scan)
    dx_scan "$@"
    ;;

  repox)
    dx_repox "$@"
    ;;

  template)
    dx_template "$@"
    ;;

  context)
    if [[ -z "${1:-}" || "${1:-}" == --* ]]; then
      dx_context "$@"
      exit $?
    fi
    config_validate_atlassian
    _atlassian_init
    dx_context "$@"
    ;;

  ci)
    dx_ci "$@"
    ;;

  guard)
    dx_guard "$@"
    ;;

  env)
    dx_env "$@"
    ;;

  doctor)
    dx_doctor "$@"
    ;;

  mr)
    config_validate_atlassian
    _atlassian_init
    SUB="${1:-}"
    [[ $# -gt 0 ]] && shift || true
    case "$SUB" in
      open) config_validate_gitlab; gitlab_mr_open "$@" ;;
      body) dx_review_body MR "$@" ;;
      list) gitlab_mr_list ;;
      view) gitlab_mr_view "$@" ;;
      *)    echo "Usage: dx mr open|body|list|view" >&2; exit 1 ;;
    esac
    ;;

  pr)
    config_validate_atlassian
    _atlassian_init
    SUB="${1:-}"
    [[ $# -gt 0 ]] && shift || true
    case "$SUB" in
      open) config_validate_github; github_pr_open "$@" ;;
      body) dx_review_body PR "$@" ;;
      list) github_pr_list ;;
      view) github_pr_view "$@" ;;
      *)    echo "Usage: dx pr open|body|list|view" >&2; exit 1 ;;
    esac
    ;;

  auth)
    SUB="${1:-}"
    [[ $# -gt 0 ]] && shift || true
    case "$SUB" in
      login)   cmd_auth_login ;;
      profile) cmd_auth_profile "$@" ;;
      default) cmd_auth_default "$@" ;;
      switch)  cmd_auth_switch "$@" ;;
      whoami)  cmd_auth_whoami ;;
      *)       echo "Usage: dx auth login|profile|default|switch|whoami" >&2; exit 1 ;;
    esac
    ;;

  profile)
    cmd_auth_profile "$@"
    ;;

  help|--help|-h)
    _dx_help
    ;;

  version|--version)
    dx_version
    ;;

  update)
    dx_update "$@"
    ;;

  *)
    echo "Unknown command: $CMD. Run: dx help" >&2
    exit 1
    ;;
esac
